#!/bin/sh
echo "Status: 200 OK"
echo "Content-Type: application/json"
echo "Cache-Control: no-cache, no-store, must-revalidate"
echo ""

# CPU stat (shell builtin read, no fork)
IFS= read -r cpu_stat < /proc/stat

# Memory info (shell builtins only, no fork)
mem_total=""
mem_avail=""
while read key val unit; do
    case "$key" in
        MemTotal:) mem_total=$val ;;
        MemAvailable:) mem_avail=$val ;;
    esac
    [ -n "$mem_total" ] && [ -n "$mem_avail" ] && break
done < /proc/meminfo
if [ -z "$mem_avail" ]; then
    mem_avail=$(awk '/MemFree|Buffers|^Cached:/ {sum+=$2} END {print sum}' /proc/meminfo)
fi

# Storage info (single df + awk per filesystem)
set -- $(df -k / | awk 'NR==2 {gsub(/%/,"",$5); print $2, $4, $5}')
rom_total=${1:-0}
rom_avail=${2:-0}
rom_perc=${3:-0}

overlay=$(df -k /overlay 2>/dev/null | awk 'NR==2 {print $2, $4}')
if [ -n "$overlay" ]; then
    set -- $overlay
    rom_total=${1:-$rom_total}
    rom_avail=${2:-$rom_avail}
fi

# CPU temperature (shell builtin read, no fork)
cpu_temp=""
cpu_temp_raw=""
for f in /sys/class/hwmon/hwmon*/temp*_input; do
    [ -f "$f" ] && { IFS= read -r cpu_temp_raw < "$f"; break; }
done 2>/dev/null
if [ -n "$cpu_temp_raw" ] && [ "$cpu_temp_raw" -eq "$cpu_temp_raw" ] 2>/dev/null; then
    cpu_temp=$((cpu_temp_raw / 1000))
fi

cat <<EOF
{
  "cpu": "$cpu_stat",
  "cpu_temp": "$cpu_temp",
  "rom_perc": "$rom_perc",
  "rom_avail": "$rom_avail",
  "rom_total": "$rom_total",
  "mem_total": "$mem_total",
  "mem_avail": "$mem_avail"
}
EOF
